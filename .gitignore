# ============================================
# PRODUCTION DEPLOYMENT .gitignore
# ============================================
# This file specifies which files should NOT be committed to Git
# dist/ is NOT ignored - it's needed for deployment

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Environment Variables (NEVER COMMIT)
# ============================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# Build & Runtime
# ============================================
# dist/ - KEEP THIS FOR DEPLOYMENT
dist-ssr/
build/
out/
*.local

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Runtime Data
# ============================================
pids/
*.pid
*.seed
*.pid.lock

# ============================================
# Coverage & Testing
# ============================================
coverage/
.nyc_output/
.jest/
.mocha/
.test/

# ============================================
# IDE & Editor Files
# ============================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# OS Files
# ============================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================
# Cache Files
# ============================================
.cache/
.eslintcache
.stylelintcache
.grunt/

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak
*.backup
*~

# ============================================
# Compiled Files
# ============================================
*.o
*.obj
*.exe
*.out

# ============================================
# Dependency Directories
# ============================================
jspm_packages/
bower_components/

# ============================================
# TypeScript
# ============================================
typings/
*.tsbuildinfo

# ============================================
# Misc
# ============================================
.lock-wscript
.grunt/
.node_repl_history

# ============================================
# Optional npm cache directory
# ============================================
.npm

# ============================================
# Optional REPL history
# ============================================
.node_repl_history

# ============================================
# Output of 'npm pack'
# ============================================
*.tgz

# ============================================
# Backup files
# ============================================
*.bak
*.backup

# ============================================
# IDE specific
# ============================================
.vscode/settings.json
.vscode/extensions.json
.idea/
*.iml

# ============================================
# Documentation build files
# ============================================
docs/_build/
site/

# ============================================
# Documentation Files (Not needed for deployment)
# ============================================
INTERVIEW_QUESTIONS_AND_ANSWERS.md
PROJECT_FLOWCHART_AND_ARCHITECTURE.md
PROJECT_DETAILED_EXPLANATION.md
INTERVIEW_AND_DOCUMENTATION_SUMMARY.md
COMPLETE_DOCUMENTATION_INDEX.md
DEPLOYMENT_GUIDE.md
DEPLOYMENT.md
PRODUCTION_CHECKLIST.md
PRODUCTION_DEPLOYMENT_SUMMARY.md
PRODUCTION_READY_FINAL_SUMMARY.md
PRODUCTION_README.md
PRODUCTION_READY.md
PRODUCTION_SUMMARY.md
DEVELOPMENT.md
QUICKSTART.md
README.md
PROJECT_SUMMARY.md
DOCUMENTATION_INDEX.md
CONTACT_FEATURE_COMPLETE.md
CONTACT_FEATURE_GUIDE.md
CONTACT_IMPLEMENTATION_SUMMARY.md
CONTACT_SETUP.md
DESIGN_PAGE_COMPLETE.md
DESIGN_PAGE_GUIDE.md
PR_PAGE_COMPLETE.md
PERFORMANCE.md
COMPLETION_SUMMARY.md

# ============================================
# IMPORTANT: dist/ is NOT ignored
# ============================================
# The dist/ folder contains the production build
# and MUST be committed for deployment
# DO NOT add dist/ to this file

# Assignment Response Document
ASSIGNMENT_RESPONSE.md
ASSIGNMENT_SUBMISSION_GUIDE.md
